{
  "name": "@jxburros/context-nugget",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "description": "A pliable context and memory scaffolding engine for AI apps.",
  "license": "MIT",
  "author": "jxburros",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jxburros/AI-Context-Nugget.git"
  },
  "bugs": {
    "url": "https://github.com/jxburros/AI-Context-Nugget/issues"
  },
  "homepage": "https://github.com/jxburros/AI-Context-Nugget#readme",
  "keywords": [
    "ai",
    "llm",
    "context",
    "memory",
    "rag",
    "retrieval",
    "bm25",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./ai-nugget": {
      "types": "./dist/src/ai-nugget.d.ts",
      "import": "./dist/src/ai-nugget.js",
      "default": "./dist/src/ai-nugget.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "design.md",
    "CHANGELOG.md",
    "recipes",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "node --test tests/*.test.mjs",
    "prepublishOnly": "npm run typecheck && npm run build && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
